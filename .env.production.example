COMPOSE_PROJECT_NAME=seedflower
BASE_IMAGE=node:22-bookworm-slim
POSTGRES_DB=seedflower
POSTGRES_USER=seedflower
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://seedflower:replace-with-strong-password@postgres:5432/seedflower
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3045
STORAGE_DIR=/app/.runtime-storage
REMINDER_SCAN_INTERVAL_MS=30000
REMINDER_LOOKAHEAD_MINUTES=10
CADDY_SITE_ADDRESS=:80
PUBLIC_BASE_URL=http://127.0.0.1
PUBLIC_API_PREFIX=/api
OPENCLAW_PLUGIN_SOURCE=/home/admin/agri-orchestrator-main
OPENCLAW_CONFIG_PATH=/home/admin/.openclaw/openclaw.json
OPENCLAW_STATE_DIR=/home/admin/.openclaw
